<?xml version='1.0' encoding='utf-8'?>
<widget id="com.premiumcalculator.aryan" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Premium Calculator</name>
    <description>
        A premium calculator app by Aryan with a custom unlock paywall prank.
    </description>
    <author email="aryan@example.com">
        Aryan
    </author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
